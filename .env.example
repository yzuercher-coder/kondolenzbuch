# ── Datenbank (Neon PostgreSQL) ───────────────────────────────────────────────
# Von Neon Dashboard: Settings → Connection string → Pooled connection
DATABASE_URL="postgresql://user:password@ep-xxx.eu-central-1.aws.neon.tech/neondb?sslmode=require&pgbouncer=true"

# Von Neon Dashboard: Settings → Connection string → Direct connection
DIRECT_URL="postgresql://user:password@ep-xxx.eu-central-1.aws.neon.tech/neondb?sslmode=require"

# ── NextAuth ──────────────────────────────────────────────────────────────────
# Zufälliger String: openssl rand -base64 32
NEXTAUTH_SECRET="ihr-zufaelliger-geheimer-schluessel"

# Ihre Vercel-Domain (wird automatisch von Vercel gesetzt)
NEXTAUTH_URL="https://ihr-projekt.vercel.app"

# ── Vercel Blob (für Bild-Uploads) ────────────────────────────────────────────
# Von Vercel Dashboard: Storage → Blob → Token
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."

# ── E-Mail (SendGrid) ─────────────────────────────────────────────────────────
# Von SendGrid: Settings → API Keys
SENDGRID_API_KEY="SG...."

# Absender-Adresse (muss in SendGrid verifiziert sein)
EMAIL_FROM="noreply@ihre-domain.ch"

# ── Cron Job ──────────────────────────────────────────────────────────────────
# Zufälliger String zum Absichern des Cron-Endpunkts
CRON_SECRET="ihr-cron-secret"
