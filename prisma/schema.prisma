generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Unternehmen ──────────────────────────────────────────────────────────────

model Unternehmen {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  website     String?
  logoUrl     String?
  widgetToken String   @unique @default(cuid())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  benutzer      User[]
  todesanzeigen Todesanzeige[]
}

// ─── Admin-Benutzer ───────────────────────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      String   @default("ADMIN")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  unternehmenId String?
  unternehmen   Unternehmen? @relation(fields: [unternehmenId], references: [id])

  todesanzeigen Todesanzeige[]
}

// ─── Todesanzeige ─────────────────────────────────────────────────────────────

model Todesanzeige {
  id          String   @id @default(cuid())
  slug        String   @unique
  status      String   @default("ENTWURF")

  // Verstorbene Person
  vorname     String
  nachname    String
  geburtstag  DateTime?
  sterbetag   DateTime
  portraitUrl      String?
  stimmungsbildUrl String?
  wohnort          String?

  // Abschiedsfeier
  abschiedsfeierDatum       DateTime?
  abschiedsfeierOrt         String?
  abschiedsfeierBemerkungen String?   @db.Text

  // Texte
  trauerspruch   String?   @db.Text
  nachruf        String?   @db.Text
  hinterbliebene String?   @db.Text

  // Konfiguration Kondolenzbuch
  kondolenzAktiv        Boolean   @default(true)
  kondolenzBis          DateTime?
  moderationAktiv       Boolean   @default(true)
  benachrichtigungEmail String?

  // Einbettung (einzelne Anzeige)
  einbettungsToken String @unique @default(cuid())

  // Unternehmen
  unternehmenId String?
  unternehmen   Unternehmen? @relation(fields: [unternehmenId], references: [id])

  // Metadaten
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String
  creator   User     @relation(fields: [createdBy], references: [id])

  kondolenzEintraege KondolenzEintrag[]
}

// ─── Kondolenz-Eintrag ────────────────────────────────────────────────────────

model KondolenzEintrag {
  id             String       @id @default(cuid())
  todesanzeigeId String
  todesanzeige   Todesanzeige @relation(fields: [todesanzeigeId], references: [id], onDelete: Cascade)

  // Absender
  name      String
  ort       String?
  beziehung String?

  // Inhalt
  nachricht             String    @db.Text
  bildUrl               String?
  status                String    @default("AUSSTEHEND")
  datenschutzZustimmung Boolean   @default(false)
  gemeldet              Boolean   @default(false)
  gemeldedAt            DateTime?

  // UC-018: KI-Moderation
  kiEmpfehlung  String?
  kiBegruendung String?

  // Edit-Token für UC-012
  editToken String?   @unique
  editBis   DateTime?

  // Metadaten
  createdAt     DateTime  @default(now())
  freigegebenAt DateTime?
  ipAdresse     String?
  email         String?
}
